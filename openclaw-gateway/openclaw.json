{
  "agents": {
    "defaults": {
      "workspace": "/root/.openclaw/workspace",
      "model": {
        "primary": "gemini/gemini-2.0-flash",
        "fallbacks": [
          "openrouter/auto",
          "deepseek/deepseek-chat",
          "openrouter/moonshotai/kimi-k2-5"
        ]
      },
      "models": {
        "gemini/gemini-2.0-flash": {
          "alias": "default"
        },
        "gemini/gemini-2.0-flash-lite": {
          "alias": "lite"
        },
        "openrouter/auto": {
          "alias": "free"
        },
        "deepseek/deepseek-chat": {
          "alias": "deepseek-direct"
        },
        "openrouter/deepseek/deepseek-chat": {
          "alias": "brain"
        },
        "openrouter/deepseek/deepseek-reasoner": {
          "alias": "subagent"
        },
        "openrouter/anthropic/claude-opus-4-6": {
          "alias": "brain-best"
        },
        "openrouter/moonshotai/kimi-k2-5": {
          "alias": "brain-savings"
        },
        "openrouter/openai/codex-mini-high": {
          "alias": "coding"
        },
        "openrouter/minimax/minimax-m1": {
          "alias": "coding-savings"
        },
        "openrouter/perplexity/sonar": {
          "alias": "research"
        }
      },
      "heartbeat": {
        "every": "30m",
        "model": "gemini/gemini-2.0-flash",
        "target": "telegram"
      },
      "memorySearch": {
        "sources": [
          "memory",
          "sessions"
        ],
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.5,
            "textWeight": 0.5
          }
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "6h",
        "keepLastAssistants": 3
      },
      "compaction": {
        "mode": "default",
        "reserveTokensFloor": 30000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 40000,
          "prompt": "Before this context is compacted, extract and save all important information to memory files. Focus on: 1. DECISIONS made (what was decided and why). 2. STATE CHANGES (what was configured, installed, or modified). 3. LESSONS LEARNED (what worked, what failed, key insights). 4. BLOCKERS waiting for input. 5. Key facts about projects, people, or systems. Write to /root/.openclaw/workspace/memory/ files. Do not skip — missing context is permanently lost after compaction."
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "custom",
    "customBindHost": "0.0.0.0",
    "port": 18789,
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_OPENCLAW_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "916838588",
        "8250567910",
        "5235733821"
      ],
      "groups": {
        "-1003699307481": {
          "enabled": true,
          "requireMention": false
        }
      }
    },
    "slack": {
      "enabled": false,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "signingSecret": "${SLACK_SIGNING_SECRET}",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "*"
      ]
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "enabled": true,
        "maxChars": 100000,
        "timeoutSeconds": 30
      },
      "search": {
        "provider": "perplexity",
        "perplexity": {
          "apiKey": "${OPENROUTER_API_KEY}",
          "baseUrl": "https://openrouter.ai/api/v1",
          "model": "perplexity/sonar"
        }
      }
    },
    "exec": {
      "host": "gateway",
      "security": "allowlist",
      "ask": "on-miss",
      "safeBins": [
        "node",
        "curl",
        "jq",
        "date",
        "echo"
      ]
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "sessionRetention": "24h"
  },
  "skills": {
    "entries": {
      "web-search": {
        "enabled": true
      },
      "file-ops": {
        "enabled": true
      },
      "reminders": {
        "enabled": true
      },
      "qmd": {
        "enabled": true
      }
    }
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true
  },
  "plugins": {
    "entries": {
      "llm-task": {
        "enabled": true
      }
    }
  }
}