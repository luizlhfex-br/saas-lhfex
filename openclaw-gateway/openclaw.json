{
  // ── AGENT DEFAULTS ───────────────────────────────────────────────────────
  "agents": {
    "defaults": {
      "workspace": "/root/.openclaw/workspace",

      // Hierarquia de 4 camadas — troca automática por ordem
      // Camada 1: Gemini direto (grátis, primário, ~1500 req/dia)
      // Camada 2: OpenRouter /auto (roteador grátis — escolhe o melhor free disponível)
      // Camada 3: DeepSeek direto (pago, tokens já comprados — usar até acabar)
      // Camada 4: Kimi K2.5 via OpenRouter (econômico, custo mínimo)
      "model": {
        "primary": "gemini/gemini-2.0-flash",
        "fallbacks": [
          "openrouter/auto",
          "deepseek/deepseek-chat",
          "openrouter/moonshotai/kimi-k2-5"
        ]
      },

      // Catálogo de modelos disponíveis + aliases
      "models": {
        "gemini/gemini-2.0-flash":               { "alias": "default"        },
        "gemini/gemini-2.0-flash-lite":          { "alias": "lite"           },
        "openrouter/auto":                        { "alias": "free"           },
        "deepseek/deepseek-chat":                { "alias": "deepseek-direct" },
        "openrouter/deepseek/deepseek-chat":     { "alias": "brain"          },
        "openrouter/deepseek/deepseek-reasoner": { "alias": "subagent"       },
        "openrouter/anthropic/claude-opus-4-6":  { "alias": "brain-best"     },
        "openrouter/moonshotai/kimi-k2-5":       { "alias": "brain-savings"  },
        "openrouter/openai/codex-mini-high":     { "alias": "coding"         },
        "openrouter/minimax/minimax-m1":         { "alias": "coding-savings" },
        "openrouter/perplexity/sonar":           { "alias": "research"       }
      },

      // Heartbeat a cada 15 min usando modelo primário
      // Quiet hours (00h-05h BRT): implementado via SOUL.md + cron schedules
      "heartbeat": {
        "every":  "15m",
        "model":  "gemini/gemini-2.0-flash",
        "target": "telegram"
      }
    }
  },

  // ── GATEWAY ──────────────────────────────────────────────────────────────
  // bind=custom+0.0.0.0 para funcionar no Docker (Coolify proxy)
  // mode=local é obrigatório — sem isso o gateway bloqueia com:
  // "Gateway start blocked: set gateway.mode=local or pass --allow-unconfigured"
  "gateway": {
    "mode":           "local",
    "bind":           "custom",
    "customBindHost": "0.0.0.0",
    "port":           18789,
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },

  // ── CANAIS ───────────────────────────────────────────────────────────────
  "channels": {
    "telegram": {
      "enabled":   true,
      "botToken":  "${TELEGRAM_OPENCLAW_BOT_TOKEN}",
      "dmPolicy":  "allowlist",
      "allowFrom": ["916838588", "8250567910", "5235733821"],
      "groups":    { "*": { "enabled": false } }
    },
    "slack": {
      "enabled":       false,
      "botToken":      "${SLACK_BOT_TOKEN}",
      "appToken":      "${SLACK_APP_TOKEN}",
      "signingSecret": "${SLACK_SIGNING_SECRET}",
      "dmPolicy":      "allowlist",
      "allowFrom":     ["*"]
    }
  },

  // ── TOOLS ────────────────────────────────────────────────────────────────
  // web_fetch habilitado para o agente chamar a API SAAS diretamente
  "tools": {
    "web": {
      "fetch": {
        "enabled":       true,
        "maxChars":      100000,
        "timeoutSeconds": 30
      }
    }
  },

  // ── CRON (scheduler config) ──────────────────────────────────────────────
  // Jobs definidos via CLI após o container iniciar (ver entrypoint.sh)
  "cron": {
    "enabled":           true,
    "maxConcurrentRuns": 2,
    "sessionRetention":  "24h"
  },

  // ── SKILLS ───────────────────────────────────────────────────────────────
  "skills": {
    "entries": {
      "web-search": { "enabled": true  },
      "file-ops":   { "enabled": true  },
      "reminders":  { "enabled": true  },
      "qmd":        { "enabled": true  }
    }
  },

  // ── MEMÓRIA (Fase 4 — Bruno Okamoto) ─────────────────────────────────────
  // Busca híbrida BM25+vector, TTL 6h, flush 40k tokens, últimas 3 respostas
  "memorySearch": {
    "sources": ["memory", "sessions"],
    "query": {
      "hybrid": {
        "enabled":     true,
        "vectorWeight": 0.5,
        "textWeight":  0.5
      }
    }
  },

  "contextPruning": {
    "mode":               "cache-ttl",
    "ttl":                "6h",
    "keepLastAssistants": 3
  },

  "compaction": {
    "mode":                   "default",
    "reserveTokensFloor":     30000,
    "memoryFlush": {
      "enabled":              true,
      "softThresholdTokens":  40000,
      "prompt": "Before this context is compacted, extract and save all important information to memory files. Focus on: 1. DECISIONS made (what was decided and why). 2. STATE CHANGES (what was configured, installed, or modified). 3. LESSONS LEARNED (what worked, what failed, key insights). 4. BLOCKERS waiting for input. 5. Key facts about projects, people, or systems. Write to /root/.openclaw/workspace/memory/ files. Do not skip — missing context is permanently lost after compaction."
    }
  }
}
