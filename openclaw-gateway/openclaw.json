{
  "agents": {
    "defaults": {
      "workspace": "/root/.openclaw/workspace",
      "model": {
        "primary": "vertex/gemini-2.0-flash",
        "fallbacks": [
          "openrouter/qwen-2.5-72b-instruct:free",
          "deepseek/deepseek-chat"
        ]
      },
      "thinkingDefault": "adaptive",
      "pdfModel": "vertex/gemini-2.0-flash",
      "pdfMaxBytesMb": 10,
      "pdfMaxPages": 20,
      "models": {
        "vertex/gemini-2.0-flash": {
          "alias": "default"
        },
        "openrouter/qwen-2.5-72b-instruct:free": {
          "alias": "free-qwen"
        },
        "openrouter/meta-llama/llama-3.3-70b-instruct:free": {
          "alias": "free-llama"
        },
        "openrouter/deepseek/deepseek-r1-distill-llama-70b:free": {
          "alias": "free-r1"
        },
        "deepseek/deepseek-chat": {
          "alias": "deepseek-direct"
        },
        "openrouter/openai/codex-mini-high": {
          "alias": "coding"
        },
        "openrouter/perplexity/sonar": {
          "alias": "research"
        }
      },
      "heartbeat": {
        "every": "30m",
        "model": "vertex/gemini-2.0-flash",
        "target": "telegram"
      },
      "memorySearch": {
        "sources": [
          "memory",
          "sessions"
        ],
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.5,
            "textWeight": 0.5
          }
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "6h",
        "keepLastAssistants": 3
      },
      "compaction": {
        "mode": "default",
        "reserveTokensFloor": 30000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 40000,
          "prompt": "Before this context is compacted, extract and save all important information to memory files. Focus on decisions, state changes, lessons learned, blockers and key project facts. Write to /root/.openclaw/workspace/memory/. Do not skip because missing context is permanently lost after compaction."
        }
      }
    },
    "list": [
      {
        "id": "airton",
        "workspace": "/root/.openclaw/workspace/agents/airton",
        "model": {
          "primary": "vertex/gemini-2.0-flash",
          "fallbacks": [
            "openrouter/qwen-2.5-72b-instruct:free",
            "deepseek/deepseek-chat"
          ]
        }
      },
      {
        "id": "iana",
        "workspace": "/root/.openclaw/workspace/agents/iana",
        "model": {
          "primary": "vertex/gemini-2.0-flash",
          "fallbacks": [
            "openrouter/qwen-2.5-72b-instruct:free",
            "deepseek/deepseek-chat"
          ]
        }
      },
      {
        "id": "maria",
        "workspace": "/root/.openclaw/workspace/agents/maria",
        "model": {
          "primary": "vertex/gemini-2.0-flash",
          "fallbacks": [
            "openrouter/qwen-2.5-72b-instruct:free",
            "deepseek/deepseek-chat"
          ]
        }
      },
      {
        "id": "iago",
        "workspace": "/root/.openclaw/workspace/agents/iago",
        "model": {
          "primary": "vertex/gemini-2.0-flash",
          "fallbacks": [
            "openrouter/qwen-2.5-72b-instruct:free",
            "deepseek/deepseek-chat"
          ]
        }
      },
      {
        "id": "iara",
        "workspace": "/root/.openclaw/workspace/agents/iara",
        "model": {
          "primary": "vertex/gemini-2.0-flash",
          "fallbacks": [
            "openrouter/qwen-2.5-72b-instruct:free",
            "deepseek/deepseek-chat"
          ]
        }
      },
      {
        "id": "sofia",
        "workspace": "/root/.openclaw/workspace/agents/sofia",
        "model": {
          "primary": "vertex/gemini-2.0-flash",
          "fallbacks": [
            "openrouter/qwen-2.5-72b-instruct:free",
            "deepseek/deepseek-chat"
          ]
        }
      },
      {
        "id": "mai",
        "workspace": "/root/.openclaw/workspace/agents/mai",
        "model": {
          "primary": "vertex/gemini-2.0-flash",
          "fallbacks": [
            "openrouter/qwen-2.5-72b-instruct:free",
            "deepseek/deepseek-chat"
          ]
        }
      },
      {
        "id": "julia",
        "workspace": "/root/.openclaw/workspace/agents/julia",
        "model": {
          "primary": "vertex/gemini-2.0-flash",
          "fallbacks": [
            "openrouter/qwen-2.5-72b-instruct:free",
            "deepseek/deepseek-chat"
          ]
        }
      }
    ]
  },
  "gateway": {
    "mode": "local",
    "bind": "custom",
    "customBindHost": "0.0.0.0",
    "port": 18789,
    "auth": {
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 60000,
        "lockoutMs": 300000
      }
    },
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": false,
      "allowedOrigins": [
        "https://nw8cc8s8c8kkcgkggocccgw4.72.60.151.145.sslip.io",
        "http://nw8cc8s8c8kkcgkggocccgw4.72.60.151.145.sslip.io"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_OPENCLAW_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "916838588",
        "8250567910",
        "5235733821"
      ],
      "groups": {
        "-1003699307481": {
          "enabled": true,
          "requireMention": false,
          "allowFrom": [
            "916838588",
            "8250567910",
            "5235733821"
          ]
        }
      }
    },
    "slack": {
      "enabled": false,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "signingSecret": "${SLACK_SIGNING_SECRET}",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "*"
      ]
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "enabled": true,
        "maxChars": 100000,
        "timeoutSeconds": 30
      },
      "search": {
        "provider": "perplexity",
        "perplexity": {
          "apiKey": "${OPENROUTER_API_KEY}",
          "baseUrl": "https://openrouter.ai/api/v1",
          "model": "perplexity/sonar"
        }
      }
    },
    "exec": {
      "host": "gateway",
      "security": "allowlist",
      "ask": "on-miss",
      "safeBinTrustedDirs": [
        "/usr/local/bin"
      ],
      "safeBins": [
        "curl",
        "jq",
        "date",
        "echo",
        "openclaw"
      ],
      "safeBinProfiles": {
        "curl": {},
        "jq": {},
        "date": {},
        "echo": {},
        "openclaw": {}
      }
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "sessionRetention": "24h"
  },
  "skills": {
    "entries": {
      "web-search": {
        "enabled": true
      },
      "file-ops": {
        "enabled": true
      },
      "reminders": {
        "enabled": true
      },
      "qmd": {
        "enabled": true
      }
    }
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true
  },
  "plugins": {
    "entries": {
      "llm-task": {
        "enabled": true
      }
    }
  }
}
